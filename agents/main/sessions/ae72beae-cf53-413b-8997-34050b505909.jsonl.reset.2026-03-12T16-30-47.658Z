tle=\"macOS Signing\"><a class=\"group flex items-start pr-3 py-1.5 cursor-pointer gap-x-3 text-left rounded-xl w-full outline-offset-[-1px] hover:bg-gray-600/5 dark:hover:bg-gray-200/5 text-gray-700 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300\" style=\"padding-left:1rem\" href=\"/platforms/mac/signing\"><div class=\"flex-1 flex items-start space-x-2.5\"><div class=\"break-words [word-break:break-word]\">macOS Signing</div></div></a></li><li id=\"/platforms/mac/release\" class=\"relative scroll-m-4 first:scroll-m-20\" data-title=\"macOS Release\"><a class=\"group flex items-start pr-3 py-1.5 cursor-pointer gap-x-3 text-left rounded-xl w-full outline-offset-[-1px] hover:bg-gray-600/5 dark:hover:bg-gray-200/5 text-gray-700 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300\" style=\"padding-left:1rem\" href=\"/platforms/mac/release\"><div class=\"flex-1 flex items-start space-x-2.5\"><div class=\"break-words [word-break:break-word]\">macOS Release</div></div></a></li><li id=\"/platforms/mac/bundled-gateway\" class=\"relative scroll-m-4 first:scroll-m-20\" data-title=\"Gateway on macOS\"><a class=\"group flex items-start pr-3 py-1.5 cursor-pointer gap-x-3 text-left rounded-xl w-full outline-offset-[-1px] hover:bg-gray-600/5 dark:hover:bg-gray-200/5 text-gray-700 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300\" style=\"padding-left:1rem\" href=\"/platforms/mac/bundled-gateway\"><div class=\"flex-1 flex items-start space-x-2.5\"><div class=\"break-words [word-break:break-word]\">Gateway on macOS</div></div></a></li><li id=\"/platforms/mac/xpc\" class=\"relative scroll-m-4 first:scroll-m-20\" data-title=\"macOS IPC\"><a class=\"group flex items-start pr-3 py-1.5 cursor-pointer gap-x-3 text-left rounded-xl w-full outline-offset-[-1px] hover:bg-gray-600/5 dark:hover:bg-gray-200/5 text-gray-700 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300\" style=\"padding-left:1rem\" href=\"/platforms/mac/xpc\"><div class=\"flex-1 flex items-start space-x-2.5\"><div class=\"break-words [word-break:break-word]\">macOS IPC</div></div></a></li><li id=\"/platforms/mac/skills\" class=\"relative scroll-m-4 first:scroll-m-20\" data-title=\"Skills\"><a class=\"group flex items-start pr-3 py-1.5 cursor-pointer gap-x-3 text-left break-words hyphens-auto rounded-xl w-full outline-offset-[-1px] hover:bg-gray-600/5 dark:hover:bg-gray-200/5 text-gray-700 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300\" style=\"padding-left:1rem\" href=\"/platforms/mac/skills\"><div class=\"flex-1 flex items-start space-x-2.5\"><div class=\"break-words [word-break:break-word]\">Skills</div></div></a></li><li id=\"/platforms/mac/peekaboo\" class=\"relative scroll-m-4 first:scroll-m-20\" data-title=\"Peekaboo Bridge\"><a class=\"group flex items-start pr-3 py-1.5 cursor-pointer gap-x-3 text-left rounded-xl w-full outline-offset-[-1px] hover:bg-gray-600/5 dark:hover:bg-gray-200/5 text-gray-700 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300\" style=\"padding-left:1rem\" href=\"/platforms/mac/peekaboo\"><div class=\"flex-1 flex items-start space-x-2.5\"><div class=\"break-words [word-break:break-word]\">Peekaboo Bridge</div></div></a></li></ul></div></div></div></div></div><div id=\"content-container\"><script>(self.__next_s=self.__next_s||[]).push([0,{\"children\":\"document.documentElement.setAttribute('data-page-mode', 'none');\",\"id\":\"_mintlify-page-mode-script\"}])</script><script>(self.__next_s=self.__next_s||[]).push([0,{\"suppressHydrationWarning\":true,\"children\":\"(function n(a,b){let c=\\\"maple\\\"===b||\\\"willow\\\"===b||\\\"new-willow\\\"===b||\\\"almond\\\"===b||\\\"luma\\\"===b||\\\"sequoia\\\"===b;if(!document.getElementById(\\\"footer\\\")?.classList.contains(\\\"advanced-footer\\\")||c)return;let d=document.documentElement.getAttribute(\\\"data-page-mode\\\"),e=document.getElementById(\\\"navbar\\\"),f=document.getElementById(\\\"navigation-items\\\"),g=document