{
  // ─── Plugin tools ───────────────────────────────────────────────
  // Both llm-task and lobster are optional plugins, disabled by default.
  "plugins": {
    "entries": {
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "anthropic",
          "defaultModel": "claude-haiku-4-5-20251001",
          "maxTokens": 800,
          "timeoutMs": 30000
        }
      }
    }
  },

  // ─── Tool permissions ───────────────────────────────────────────
  // IMPORTANT: use alsoAllow (additive), NOT allow (restrictive).
  // "allow" puts OpenClaw in restrictive allowlist mode and blocks core tools.
  "tools": {
    "alsoAllow": ["lobster", "llm-task"]
  },

  // ─── Telegram channel ───────────────────────────────────────────
  // Replace YOUR_CHAT_ID with your actual Telegram chat ID.
  "channels": {
    "telegram": {
      "botToken": "~/.openclaw/secrets/telegram-bot-token",
      "chatId": "YOUR_CHAT_ID",
      "capabilities": {
        "inlineButtons": "dm"
      }
    }
  },

  // ─── MCP servers ────────────────────────────────────────────────
  // gws registered as an MCP server for Gmail access.
  "mcpServers": {
    "google-workspace": {
      "command": "gws",
      "args": ["mcp"]
    }
  }
}
