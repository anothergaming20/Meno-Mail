{
  // ─── Agent definitions ──────────────────────────────────────────
  // email-triage agent: Haiku, dedicated workspace context.
  // AGENTS.md, soul.md, user.md are loaded into every session automatically
  // by OpenClaw's workspace bootstrap injection.
  //
  // Register via CLI after copying identity files to the workspace:
  //   openclaw agents add email-triage \
  //     --model "anthropic/claude-haiku-4-5-20251001" \
  //     --workspace "/Users/aiagnet/.openclaw/workspace" \
  //     --non-interactive
  "agents": {
    "list": [
      {
        "id": "email-triage",
        "model": "anthropic/claude-haiku-4-5-20251001",
        "workspace": "/Users/aiagnet/.openclaw/workspace",
        "description": "Email triage agent — classifies and acts on incoming Gmail"
      }
    ]
  },

  // ─── Plugin tools ───────────────────────────────────────────────
  // llm-task: structured LLM calls from inside Lobster steps.
  // lobster: workflow runner invoked as an agent tool call.
  "plugins": {
    "entries": {
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "anthropic",
          "defaultModel": "claude-haiku-4-5-20251001",
          "maxTokens": 800,
          "timeoutMs": 30000
        }
      }
    }
  },

  // ─── Tool permissions ───────────────────────────────────────────
  // alsoAllow is additive — does NOT restrict core tools.
  // exec is needed so the agent can call lobster and shell scripts.
  "tools": {
    "alsoAllow": ["lobster", "llm-task", "exec"]
  },

  // ─── Skills ─────────────────────────────────────────────────────
  // Gmail skill (Maton): teaches the agent the Maton API patterns.
  // MATON_API_KEY is injected here so it's available in the agent session
  // and inherited by all Lobster step subshells automatically.
  "skills": {
    "entries": {
      "gmail": {
        "enabled": true,
        "env": {
          "MATON_API_KEY": "${MATON_API_KEY}"
        }
      }
    }
  },

  // ─── Telegram channel ───────────────────────────────────────────
  "channels": {
    "telegram": {
      "botToken": "~/.openclaw/secrets/telegram-bot-token",
      "capabilities": {
        "inlineButtons": "dm"
      }
    }
  },

  // ─── Cron jobs ──────────────────────────────────────────────────
  // Both jobs use agentTurn + isolated session — the correct OpenClaw pattern.
  // This gives full session transcripts in:
  //   ~/.openclaw/agents/email-triage/sessions/<sessionId>.jsonl
  // And run logs in:
  //   ~/.openclaw/cron/runs/<jobId>.jsonl
  //
  // Query with:
  //   openclaw cron runs --id email-triage-dispatcher --limit 20
  //   openclaw sessions --agent email-triage
  "cron": {
    "enabled": true,
    "sessionRetention": "7d",
    "runLog": {
      "maxBytes": "5mb",
      "keepLines": 3000
    },
    "jobs": [
      {
        // ── Email triage dispatcher ────────────────────────────────
        // Fires every 15 min. The agent fetches unprocessed email IDs
        // via Maton, then calls lobster run for each one.
        // Every action is logged in the isolated cron session transcript.
        "name": "email-triage-dispatcher",
        "schedule": { "kind": "cron", "expr": "*/15 * * * *" },
        "sessionTarget": "isolated",
        "agentId": "email-triage",
        "payload": {
          "kind": "agentTurn",
          "message": "Run the email triage pipeline. Use the exec tool to run: bash /Users/aiagnet/.openclaw/workspace/scripts/run-triage.sh",
          "lightContext": false
        },
        "delivery": {
          "mode": "none"
        }
      },
      {
        // ── Stale draft cleanup ────────────────────────────────────
        // Fires daily at 3am. Cleans pending-drafts.json entries older
        // than 48 hours. Logged in its own isolated cron session.
        "name": "cleanup-stale-drafts",
        "schedule": { "kind": "cron", "expr": "0 3 * * *" },
        "sessionTarget": "isolated",
        "agentId": "email-triage",
        "payload": {
          "kind": "agentTurn",
          "message": "Run stale draft cleanup. Use the exec tool to run: bash /Users/aiagnet/.openclaw/workspace/scripts/cleanup-stale-drafts.sh",
          "lightContext": true
        },
        "delivery": {
          "mode": "none"
        }
      }
    ]
  }
}
